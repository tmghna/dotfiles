Config {
    -- Increase size slightly for the 1080p display and use Nerd Font exclusively
    font = "xft:JetBrainsMono Nerd Font:style=Bold:size=11:antialias=true"
    , additionalFonts = [ 
         "xft:JetBrainsMono Nerd Font:size=14"     -- <fn=1> for larger icons
       , "xft:JetBrainsMono Nerd Font:size=24"     -- <fn=2> Vertical Stretcher
    ]
    , bgColor = "#1e1e2e" -- Catppuccin Mocha Base
    , fgColor = "#cdd6f4" -- Catppuccin Mocha Text
    , position = Static { xpos = 10, ypos = 5, width = 1900, height = 24 }    
    , alpha = 217         -- Matches your Rofi 85% opacity (optional, requires a compositor)
    , sepChar = "%"
    , alignSep = "}{"
       
       -- The Layout Template
       , template = "<fc=#cba6f7>  </fc> %StdinReader% }{ <fc=#cba6f7> </fc> %cpu% <fc=#585b70>󰇙</fc> <fc=#89b4fa> </fc> %memory% <fc=#585b70>󰇙</fc> %temp% <fc=#585b70>󰇙</fc> %wifi_ssid% <fc=#585b70>󰇙</fc> %wlan0% <fc=#585b70>󰇙</fc> <fc=#f9e2af>󰃠 </fc> %bright% <fc=#585b70>󰇙</fc> %speaker% <fc=#585b70>󰇙</fc> %mic% %bluetooth% %camera% <fc=#585b70>󰇙</fc> %battery% <fc=#585b70>󰇙</fc>%caffeine% <fc=#1e1e2e,#cba6f7> %date% </fc>"
       
       , commands =
            [ 
              -- CPU & Memory
              Run Cpu ["-t", "<total>%"] 50
            , Run Memory ["-t", "<usedratio>%"] 20

              -- Temperature
            , Run Com "/home/tdey/.config/xmobar/temp.sh" [] "temp" 20

              -- Brightness
            , Run Com "bash" ["-c", "brightnessctl -m | cut -d, -f4"] "bright" 1
            
              -- Volume (Using wpctl)
            , Run Com "/home/tdey/.config/xmobar/audio_status.sh" ["speaker"] "speaker" 1
            , Run Com "/home/tdey/.config/xmobar/audio_status.sh" ["mic"] "mic" 10  

              -- Bluetooth connection (Refresh at every 1s)
            , Run Com "/home/tdey/.config/xmobar/bluetooth.sh" [] "bluetooth" 10

              -- Camera Safety Lock status
            , Run Com "/home/tdey/.config/xmobar/camera.sh" [] "camera" 10
         
              -- Custom SSID Script (Runs every 2 seconds)
            , Run Com "/home/tdey/.config/xmobar/wifi_ssid.sh" [] "wifi_ssid" 20
            
              -- Network Speeds
            , Run Network "wlan0" 
                [ "-t", "<fc=#89b4fa>󰇚</fc> <rx> <fc=#fab387> 󰕒</fc> <tx>"
                , "-S", "True"
                ] 20
 
              -- Battery (REPLACE "BAT1" IF IT IS DIFFERENT)
            , Run BatteryP ["BAT1"]
                [ "-t", "<acstatus> <left>%"
	        -- Thresholds and their colors MUST go before the '--'
                , "-H", "70", "-L", "30"          
                , "-h", "#a6e3a1"                 -- High: Green
                , "-n", "#f9e2af"                 -- Mid: Yellow
                , "-l", "#f38ba8"                 -- Low: Red
                , "--"
                
                , "-O", "<fc=#89b4fa><fn=1></fn> </fc>"    
                , "-i", "<fc=#a6e3a1><fn=1></fn> </fc>"       
                
                , "-o", "<fn=1></fn> "
                ] 20

              -- Caffeine Mode
            , Run Com "/home/tdey/.config/xmobar/caffeine_status.sh" [] "caffeine" 5
                
              -- Date & Time Format
            , Run Date "%a %d/%m %H:%M" "date" 10
            
              -- Reads Xmonad Layout
            , Run StdinReader
            ]
       }
