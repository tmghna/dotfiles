Config {
    -- Increase size slightly for the 1080p display and use Nerd Font exclusively
    font = "xft:JetBrainsMono Nerd Font:style=Bold:size=12:antialias=true"
    , additionalFonts = [ "xft:JetBrainsMono Nerd Font:size=14" ] -- For larger icons
    , bgColor = "#1e1e2e" -- Catppuccin Mocha Base
    , fgColor = "#cdd6f4" -- Catppuccin Mocha Text
    , position = Static { xpos = 15, ypos = 5, width = 1890, height = 30 }
    , alpha = 217 -- Matches your Rofi 85% opacity (optional, requires a compositor)
    , sepChar = "%"
    , alignSep = "}{"
       
       -- The Layout Template
       , template = " <fc=#cba6f7>	</fc> %StdinReader% }{ <fc=#cba6f7> </fc> %cpu% | <fc=#89b4fa> </fc> %memory% | %temp% | <fc=#f9e2af>󰃠 </fc> %bright% | <fc=#fab387>󰕾</fc>  %volume% | <fc=#a6e3a1>󰖩 </fc> %wifi% | %battery% | <fc=#b4befe>󰸗  %date%</fc> "
       
       , commands =
            [ 
              -- CPU & Memory
              Run Cpu ["-t", "<total>%"] 50
            , Run Memory ["-t", "<usedratio>%"] 20

              -- Temperature
            , Run Com "/home/tdey/.config/xmobar/temp.sh" [] "temp" 20

              -- Brightness
            , Run Com "bash" ["-c", "brightnessctl -m | cut -d, -f4"] "bright" 1
            
              -- Volume (Using wpctl)
            , Run Com "bash" ["-c", "wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{if ($3 == \"[MUTED]\") print \"Muted\"; else print int($2 * 100) \"%\"}'"] "volume" 1
            
	      -- WiFi (Using NetworkManager bypass instead of the broken Wireless plugin)
            , Run Com "bash" ["-c", "nmcli -t -f active,signal dev wifi | awk -F: '/^yes/ {print $2\"%\"}'"] "wifi" 50
            
              -- Battery (REPLACE "BAT1" IF IT IS DIFFERENT)
            , Run BatteryP ["BAT1"]
                [ "-t", "<acstatus> <left>%"
	        -- Thresholds and their colors MUST go before the '--'
                , "-H", "70", "-L", "30"          
                , "-h", "#a6e3a1"                 -- High: Green
                , "-n", "#f9e2af"                 -- Mid: Yellow
                , "-l", "#f38ba8"                 -- Low: Red
                , "--"
                
                , "-O", "<fc=#89b4fa><fn=1></fn> </fc>"    
                , "-i", "<fc=#a6e3a1><fn=1></fn> </fc>"       
                
                , "-o", "<fn=1></fn> "
                ] 20
                
              -- Date & Time Format
            , Run Date "%a %d/%m/%Y %H:%M:%S" "date" 10
            
              -- Reads Xmonad Layout
            , Run StdinReader
            ]
       }
